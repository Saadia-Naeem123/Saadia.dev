# For LOCAL testing only (used by server.js via dotenv).
# Copy this file to ".env" and fill in real values — never commit ".env".
#
# On Vercel itself, these are NOT read from a file. Set the same names as
# Environment Variables in the Vercel dashboard (Project → Settings →
# Environment Variables), or via `vercel env add <NAME>`.

PORT=3000

# ---- SMTP (choose ONE provider) ----

# Option A: Gmail
# 1. Turn on 2-Step Verification on the Google account.
# 2. Create an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use that 16-character app password below (NOT your normal Gmail password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password

# Option B: SendGrid (use instead of Gmail)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Where contact form messages are delivered to
CONTACT_TO=sadianaeem060@gmail.com

# Send the visitor an automatic "thanks for reaching out" confirmation email
SEND_AUTOREPLY=false
